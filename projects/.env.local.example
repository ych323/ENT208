# ================================
# 够得着 - 环境变量配置模板
# ================================
# 使用说明：
# 1. 复制此文件并重命名为 .env.local
# 2. 填入你的实际API密钥
# ================================

# ----------------
# 智谱AI配置（必需）
# ----------------
# 获取地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=你的智谱API密钥

# 智谱API地址（无需修改）
ZHIPU_BASE_URL=https://www.aiping.cn/api/v1

# 使用的模型（无需修改）
ZHIPU_MODEL=GLM-5

# ----------------
# 服务端口（可选）
# ----------------
# 本地开发端口，默认5000
PORT=5000
